	<Folder id="00B1995B3A3C2F3F48D4">
		<name>Main Segments of the Silk Road</name>
		<visibility>0</visibility>
		<styleUrl>#__managed_style_07AE1758D13C2F3F48DC</styleUrl>
	</Folder>
	<Folder id="06354FC0353C2FC571A4">
		<name>Fantasy SIlk Road</name>
		<open>1</open>
		<styleUrl>#__managed_style_07AE1758D13C2F3F48DC</styleUrl>
		<Folder id="590D7C1A7A000001">
			<name>Tarim-Shaiel - Silk Road Geography</name>
			<description>Fantasy world based on historical Silk Road routes and locations</description>
			<styleUrl>#__managed_style_07AE1758D13C2F3F48DC</styleUrl>
			<Placemark id="590D7C1A7A000002">
				<name>Northern Route (Tianshan Corridor)</name>
				<description>
        Length: 1500 km
        Follows southern foothills of Tian Shan Mountains; northern rim of Taklamakan Desert
        Season: Spring/Summer preferred
      </description>
				<styleUrl>#__managed_style_0C3405BBEC3C2FCD7A7E</styleUrl>
				<LineString>
					<tessellate>1</tessellate>
					<coordinates>
						94.67,40.15,0 94.64,40.46,0 89.19,42.95,0 86.53,41.85,0 83.86,41.97,0 82.95,41.73,0 80.26000000000001,41.17,0 77.56999999999999,39.74,0 75.98999999999999,39.65,0 
					</coordinates>
				</LineString>
			</Placemark>
			<Placemark id="590D7C1A7A000003">
				<name>Southern Route (Kunlun Corridor)</name>
				<description>
        Length: 1200 km
        Follows northern base of Kunlun Mountains; southern rim of Taklamakan Desert
        Season: Year-round but isolated
      </description>
				<LookAt>
					<longitude>78.84866334343218</longitude>
					<latitude>38.0584032473403</latitude>
					<altitude>3424.565785511775</altitude>
					<heading>0</heading>
					<tilt>0</tilt>
					<gx:fovy>30</gx:fovy>
					<range>6682377.000546457</range>
					<altitudeMode>absolute</altitudeMode>
				</LookAt>
				<styleUrl>#__managed_style_088D4E7CE63C2FCDEA6C</styleUrl>
				<LineString>
					<tessellate>1</tessellate>
					<coordinates>
						94.67,40.15,0 94.64,40.46,0 88.06999999999999,40.52,0 88.15000000000001,39,0 85.55,38.14,0 88.73999999999999,36.21,0 81.18000000000001,37.07,0 79.92,37.12,0 77.27,38.43,0 75.98999999999999,39.65,0 
					</coordinates>
				</LineString>
			</Placemark>
			<Placemark id="590D7C1A7A000004">
				<name>Samarkand</name>
				<description>
Historical Name: Samarkand
Basis: Sogdania - Zoroastrian→Islamic; Mongol; Timurid revival
Goods: Textiles, luxury goods, paper mill (8th c)
Cultural Notes: Ancient &apos;Stone Fort&apos;; magnificent architecture; major intellectual center
Religious Tradition: Zoroastrian→Islamic
</description>
				<styleUrl>#__managed_style_0D3381AE203C304A7C14</styleUrl>
				<Point>
					<coordinates>66.97,39.65,0</coordinates>
				</Point>
			</Placemark>
			<Placemark id="590D7C1A7A000005">
				<name>Bukhara</name>
				<description>
Historical Name: Bukhara
Basis: Sogdania - Zoroastrian→Islamic; Mongol destruction &amp; revival
Goods: Trade hub, scholarship center
Cultural Notes: 5th-largest city; center of trade &amp; religion; 140+ architectural monuments
Religious Tradition: Zoroastrian→Islamic; scholarly hub
</description>
				<styleUrl>#__managed_style_0A0F9EC46A3C2FCCBDFC</styleUrl>
				<Point>
					<coordinates>64.43000000000001,39.77,0</coordinates>
				</Point>
			</Placemark>
			<Placemark id="590D7C1A7A000006">
				<name>Kashgar</name>
				<description>
Historical Name: Kashgar
Basis: Tarim Basin - Buddhist→Islamic; Chinese control (intermittent)
Goods: Abundant crops, fruits, wool, carpets, jade
Cultural Notes: Continuously inhabited 2K+ years; westernmost Chinese city; multiethnic
Religious Tradition: Buddhist→Islam; Nestorian Christians; cosmopolitan
</description>
				<styleUrl>#__managed_style_0A0F9EC46A3C2FCCBDFC</styleUrl>
				<Point>
					<coordinates>75.98999999999999,39.65,0</coordinates>
				</Point>
			</Placemark>
			<Placemark id="590D7C1A7A000007">
				<name>Tashkent</name>
				<description>
Historical Name: Tashkent
Basis: Fergana Valley region - Turkic origin; Mongol conquest
Goods: Trade hub, agriculture center
Cultural Notes: &apos;Stone City&apos;; largest city in Central Asia
Religious Tradition: Islamic (12th-13th c)
</description>
				<styleUrl>#__managed_style_0A0F9EC46A3C2FCCBDFC</styleUrl>
				<Point>
					<coordinates>69.23999999999999,41.31,0</coordinates>
				</Point>
			</Placemark>
			<Placemark id="590D7C1A7A000008">
				<name>Balkh</name>
				<description>
Historical Name: Balkh
Basis: Bactria (Afghanistan) - destroyed by Genghis Khan (1220s)
Goods: General trade hub
Cultural Notes: &apos;Mother of Cities&apos; before destruction; major oasis hub
Religious Tradition: Zoroastrian→Islamic; Buddhist influence
</description>
				<styleUrl>#__managed_style_0A0F9EC46A3C2FCCBDFC</styleUrl>
				<Point>
					<coordinates>66.90000000000001,36.76,0</coordinates>
				</Point>
			</Placemark>
			<Placemark id="590D7C1A7A000009">
				<name>Merv</name>
				<description>
Historical Name: Merv
Basis: Margiana (Turkmenistan) - destroyed by Genghis Khan&apos;s son
Goods: Trade hub, oasis
Cultural Notes: Later rebuilt as Mary; now village-sized; &apos;ruined Silk Road city&apos;
Religious Tradition: Islamic
</description>
				<styleUrl>#__managed_style_0A7B1091DB3C2FD0B0E0</styleUrl>
				<Point>
					<coordinates>61.83,37.66,0</coordinates>
				</Point>
			</Placemark>
			<Placemark id="590D7C1A7A00000A">
				<name>Dunhuang</name>
				<description>
Historical Name: Dunhuang
Basis: Gansu Corridor - Gateway to China
Goods: Gateway to China, artistic/religious hub
Cultural Notes: Mogao Caves: largest Buddhist art treasure house
Religious Tradition: Buddhist (major artistic center); Mogao Caves (366-1400 CE)
</description>
				<styleUrl>#__managed_style_3B4FE0D94E3C2FCCBDFC</styleUrl>
				<Point>
					<coordinates>94.67,40.15,0</coordinates>
				</Point>
			</Placemark>
			<Placemark id="590D7C1A7B00000B">
				<name>Khotan</name>
				<description>
Historical Name: Khotan
Basis: Tarim Basin - Buddhist state; Islamic conversion
Goods: Jade (major), carpets, oasis goods
Cultural Notes: Jade production center
Religious Tradition: Buddhist→Islamic
</description>
				<styleUrl>#__managed_style_9A07D468073C2FCCBDFC</styleUrl>
				<Point>
					<coordinates>79.92,37.12,0</coordinates>
				</Point>
			</Placemark>
			<Placemark id="590D7C1A7B00000C">
				<name>Kucha</name>
				<description>
Historical Name: Kucha
Basis: Tarim Basin - Buddhist state
Goods: Buddhist textiles, oasis trade
Cultural Notes: Kizil Caves nearby; major Buddhist center
Religious Tradition: Buddhist (major monasteries)→Islamic
</description>
				<styleUrl>#__managed_style_3B4FE0D94E3C2FCCBDFC</styleUrl>
				<Point>
					<coordinates>82.95,41.73,0</coordinates>
				</Point>
			</Placemark>
			<Placemark id="590D7C1A7B00000D">
				<name>Niya</name>
				<description>
Historical Name: Niya
Basis: Tarim Basin - Ancient oasis settlement
Goods: Local oasis goods
Cultural Notes: Ancient ruins; archaeological interest
Religious Tradition: Buddhist
</description>
				<styleUrl>#__managed_style_0A7B1091DB3C2FD0B0E0</styleUrl>
				<Point>
					<coordinates>81.18000000000001,37.07,0</coordinates>
				</Point>
			</Placemark>
			<Placemark id="590D7C1A7B00000E">
				<name>Chang&apos;an (Xi&apos;an)</name>
				<description>
Historical Name: Chang&apos;an (Xi&apos;an)
Basis: Central China - Han/Tang dynasty capitals
Goods: Silk (currency), jade incoming, horses
Cultural Notes: Eastern terminus; 12m walls built 1370; major trade destination
Religious Tradition: Chinese; Buddhism; Christianity (7th c)
</description>
				<styleUrl>#__managed_style_0A7B1091DB3C2FD0B0E0</styleUrl>
				<Point>
					<coordinates>109.26,34.34,0</coordinates>
				</Point>
			</Placemark>
		</Folder>
